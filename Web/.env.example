# 백엔드 API 주소 (기본값: http://localhost:8000)
# VITE_API_BASE_URL=http://localhost:8000

# Google Cloud Console에서 발급받은 OAuth 2.0 Client ID (유형: 웹 애플리케이션)
VITE_GOOGLE_CLIENT_ID=

# Naver Developers에서 발급받은 Client ID
VITE_NAVER_CLIENT_ID=

# Naver Developers에 등록한 콜백 URL과 정확히 일치해야 함.
# 비워두면 "현재 origin + /auth/naver/callback"이 자동으로 사용된다
# (예: http://localhost:5173/auth/naver/callback).
# VITE_NAVER_CALLBACK_URL=http://localhost:5173/auth/naver/callback

# NAVER Cloud Platform Maps 애플리케이션에서 발급받은 NCP Key ID
# (위 VITE_NAVER_CLIENT_ID 로그인 키와는 별개 — NCP 콘솔에서 Dynamic Map 활성화 후 발급,
# 허용 웹 서비스 URL에 로컬 개발 주소와 배포 도메인을 모두 등록해야 함).
# 브라우저에 노출되는 키이므로 등록된 origin으로만 제한되며, REST API Client Secret은
# 절대 이 값과 혼동하거나 프론트엔드 코드에 넣지 않는다.
VITE_NAVER_MAP_NCP_KEY_ID=
