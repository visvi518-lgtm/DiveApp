<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-variant manifest override: points the application at the debug-only
     network security config (see res/xml/network_security_config.xml). Gradle
     merges this into the main manifest for debug builds only. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
