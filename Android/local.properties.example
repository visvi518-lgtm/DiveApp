# local.properties로 복사한 뒤 실제 값을 채워넣는다 (git에 커밋되지 않음).
# sdk.dir은 Android Studio가 자동으로 채워주므로 그대로 둔다.
sdk.dir=

# Naver Developers에서 발급받은 값 (Android 플랫폼 등록: 패키지명 com.diveapp.android)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CLIENT_NAME=DiveApp

# Google Cloud Console에서 발급받은 "웹 애플리케이션" 유형 OAuth Client ID.
# Credential Manager는 Android에서도 이 Web Client ID를 serverClientId로 사용해야
# 백엔드가 검증 가능한 ID 토큰을 발급받을 수 있다 (Google 공식 아키텍처).
# 단, Google Cloud Console에 별도로 "Android" 유형 OAuth 클라이언트도
# 패키지명(com.diveapp.android) + 디버그 키스토어 SHA-1로 등록되어 있어야 한다.
GOOGLE_WEB_CLIENT_ID=

# NAVER Cloud Platform Maps 애플리케이션에서 발급받은 NCP Key ID
# (Naver Developers의 NAVER_CLIENT_ID와는 별개의 키 — NCP 콘솔에서 Dynamic Map 활성화 후 발급)
NAVER_MAP_CLIENT_ID=
